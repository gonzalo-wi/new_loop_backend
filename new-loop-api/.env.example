# Copiar a .env y completar con valores reales antes de levantar los contenedores.

# --- Base de datos (externa, ya existente) ---
# La base NO se crea en Docker: la app apunta a una base PostgreSQL que ya tenés.
# Ejemplos de DB_URL:
#   - Base en el MISMO servidor (host):  jdbc:postgresql://host.docker.internal:5432/loop_new_db
#   - Base en OTRO server de la LAN:     jdbc:postgresql://192.168.0.XX:5432/loop_new_db
DB_URL=jdbc:postgresql://host.docker.internal:5432/loop_new_db
DB_USERNAME=loop
DB_PASSWORD=cambiar_esta_password

# --- Seguridad ---
# Clave secreta para firmar los JWT (usar 64+ caracteres hex aleatorios)
JWT_SECRET=cambiar_por_una_clave_larga_y_aleatoria

# --- Integración Aguas ---
AGUAS_BASE_URL=http://192.168.0.12
AGUAS_EQUIPMENT_BASE_URL=http://192.168.0.58

# --- Integración Powerfleet (ubicación GPS de camiones) ---
POWERFLEET_BASE_URL=https://www.monitoreodeflotas.com.ar/Fleetcore.Api
POWERFLEET_USERNAME=cambiar_usuario
POWERFLEET_PASSWORD=cambiar_password

# Copiar a .env y completar con valores reales antes de levantar los contenedores.

# --- Base de datos ---
DB_NAME=loop_new_db
DB_USERNAME=loop
DB_PASSWORD=cambiar_esta_password

# --- Seguridad ---
# Clave secreta para firmar los JWT (usar 64+ caracteres hex aleatorios)
JWT_SECRET=cambiar_por_una_clave_larga_y_aleatoria

# --- Integración Aguas ---
AGUAS_BASE_URL=http://192.168.0.12
AGUAS_EQUIPMENT_BASE_URL=http://192.168.0.58
